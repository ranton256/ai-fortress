# /etc/ai-fortress/upstream.env
# Mode 0600, owned by root:root. Read by:
#   - the Bifrost systemd unit (provider keys + admin creds)
#   - /usr/local/sbin/fortress-mint (via sudo) — admin creds for /api/governance/virtual-keys
#   - /usr/local/sbin/fortress-revoke (via sudo)
#   - /usr/local/sbin/fortress-sweep (via the systemd timer, runs as root)
#
# Generate the admin password once with: openssl rand -base64 32
# Never commit a real copy of this file to git.

# Provider keys (real upstream credentials, never enter the VM)
ANTHROPIC_UPSTREAM_KEY=sk-ant-REPLACE-ME
OPENAI_UPSTREAM_KEY=sk-REPLACE-ME

# Bifrost governance API (admin basic-auth)
BIFROST_ADMIN_USERNAME=fortress-admin
BIFROST_ADMIN_PASSWORD=REPLACE-ME
