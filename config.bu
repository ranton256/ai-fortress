variant: flatcar
version: 1.1.0
passwd:
  users:
    - name: ranton
      groups: [sudo, docker]
      ssh_authorized_keys:
        - "ssh-rsa  ranton@skia"

storage:
  directories:
    - path: /opt/bin
      mode: 0755
  files:
    - path: /etc/hostname
      mode: 0644
      contents:
        inline: ai-fortress-general

systemd:
  units:
    # Mount the 'host_projects' share from the host to /projects
    - name: projects.mount
      enabled: true
      contents: |
        [Unit]
        Description=Mount General Projects Directory
        Before=docker.service
        [Mount]
        What=host_projects
        Where=/projects
        Type=virtiofs
        [Install]
        WantedBy=multi-user.target

    # Automatic gVisor (runsc) installation
    - name: install-gvisor.service
      enabled: true
      contents: |
        [Unit]
        Description=Install gVisor Runtime
        After=network-online.target
        Wants=network-online.target
        ConditionPathExists=!/opt/bin/runsc
        [Service]
        Type=oneshot
        ExecStart=/usr/bin/curl -L https://storage.googleapis.com/gvisor/releases/release/latest/x86_64/runsc -o /opt/bin/runsc
        ExecStart=/usr/bin/chmod +x /opt/bin/runsc
        RemainAfterExit=yes
        [Install]
        WantedBy=multi-user.target
