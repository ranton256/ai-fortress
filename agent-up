#!/bin/bash
PROJECT_NAME=$1
TYPE=${2:-default}

if [ -z "$PROJECT_NAME" ]; then
    echo "Usage: agent-up <project_folder> [python|default]"
    exit 1
fi

PROJECT_PATH="/projects/$PROJECT_NAME"

# Dynamic Image Selection
case $TYPE in
  python)
    IMAGE="ai-fortress/python-dev:latest"
    ;;
  *)
    IMAGE="ghcr.io/anomalyco/opencode:latest"
    ;;
esac

# Ensure the container runs as the current user to maintain 1:1 file permissions
# even if the image wasn't built with the exact matching UID.
USER_FLAGS="--user $(id -u):$(id -g)"

echo "--- Launching $TYPE Sandbox for: $PROJECT_NAME ---"

docker run -it --rm \
  $USER_FLAGS \
  --name "agent-$PROJECT_NAME-$(date +%s)" \
  --runtime=runsc \
  --security-opt label=disable \
  -v "$PROJECT_PATH:/work" \
  -w /work \
  -e OPENCODE_API_KEY \
  -e ANTHROPIC_API_KEY \
  -e OPENAI_API_KEY \
  $IMAGE
