variant: flatcar
version: 1.1.0
passwd:
  users:
    - name: ranton
      groups: [sudo, docker]
      ssh_authorized_keys:
        - "ssh-rsa  ranton@skia"

storage:
  directories:
    - path: /opt/bin
      mode: 0755
  files:
    - path: /etc/hostname
      mode: 0644
      contents:
        inline: ai-fortress-general

    # Load vsock kernel modules at boot so the in-VM shim can open /dev/vsock.
    - path: /etc/modules-load.d/vsock.conf
      mode: 0644
      contents:
        inline: |
          vsock
          vmw_vsock_virtio_transport

    # Allow the host-side agent launcher to pass VIRTUAL_KEY via SendEnv.
    # Without this, sshd silently drops the variable and the sandbox sees an empty key.
    - path: /etc/ssh/sshd_config.d/10-ai-fortress.conf
      mode: 0644
      contents:
        inline: |
          AcceptEnv VIRTUAL_KEY

    # Register gVisor (runsc) as a Docker runtime so `--runtime=runsc` works.
    # The runsc binary itself is installed by install-gvisor.service.
    - path: /etc/docker/daemon.json
      mode: 0644
      contents:
        inline: |
          {
            "runtimes": {
              "runsc": {
                "path": "/opt/bin/runsc"
              }
            }
          }

systemd:
  units:
    # Mount the 'host_projects' share from the host to /projects
    - name: projects.mount
      enabled: true
      contents: |
        [Unit]
        Description=Mount General Projects Directory
        Before=docker.service
        [Mount]
        What=host_projects
        Where=/projects
        Type=virtiofs
        [Install]
        WantedBy=multi-user.target

    # Automatic gVisor (runsc) installation
    - name: install-gvisor.service
      enabled: true
      contents: |
        [Unit]
        Description=Install gVisor Runtime
        After=network-online.target
        Wants=network-online.target
        ConditionPathExists=!/opt/bin/runsc
        [Service]
        Type=oneshot
        ExecStart=/usr/bin/curl -L https://storage.googleapis.com/gvisor/releases/release/latest/x86_64/runsc -o /opt/bin/runsc
        ExecStart=/usr/bin/chmod +x /opt/bin/runsc
        RemainAfterExit=yes
        [Install]
        WantedBy=multi-user.target

    # vsock shim: bridges TCP traffic on the internal sandbox_net to the
    # host's vsock listener (CID 2:4000). Sandboxes reach the LiteLLM proxy
    # via "authproxy:4000" on this bridge. Pin the alpine/socat digest before
    # treating this as production.
    - name: vsock-shim.service
      enabled: true
      contents: |
        [Unit]
        Description=AI Fortress vsock shim (TCP -> vsock)
        After=docker.service projects.mount
        Requires=docker.service

        [Service]
        Restart=always
        RestartSec=5
        ExecStartPre=-/usr/bin/docker rm -f vsock-shim
        ExecStartPre=/bin/sh -c '/usr/bin/docker network inspect sandbox_net >/dev/null 2>&1 || \
          /usr/bin/docker network create --driver bridge --internal sandbox_net'
        ExecStart=/usr/bin/docker run --rm --name vsock-shim \
          --network sandbox_net \
          --network-alias authproxy \
          --device /dev/vsock \
          --security-opt seccomp=unconfined \
          alpine/socat@sha256:ca728ccb1eabd4850ee9063d50e1899a0171bdd9002f7a4126f2925578331063 \
          -ly \
          TCP-LISTEN:4000,reuseaddr,fork,nodelay \
          VSOCK-CONNECT:2:4000
        ExecStop=/usr/bin/docker stop vsock-shim

        [Install]
        WantedBy=multi-user.target
